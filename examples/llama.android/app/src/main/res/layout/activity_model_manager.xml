<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ModelManagerActivity">

    <LinearLayout
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:context=".ModelManagerActivity"
        android:contentDescription="模型管理页面">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:background="?attr/colorPrimaryContainer"
            android:contentDescription="页面标题栏">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="模型管理"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnPrimaryContainer"
                android:contentDescription="模型管理"
                android:importantForAccessibility="yes" />

            <ImageButton
                android:id="@+id/closeButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/outline_close_24"
                android:contentDescription="关闭，返回聊天页面"
                app:tint="?attr/colorOnPrimaryContainer" />

        </LinearLayout>

        <!-- Import Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/importButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:text="导入模型"
            android:textSize="16sp"
            android:contentDescription="从手机文件夹导入模型文件"
            app:icon="@drawable/outline_folder_open_24"
            app:iconGravity="textStart" />

        <!-- Models List Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="已导入的模型"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:contentDescription="已导入的模型列表"
            android:importantForAccessibility="yes" />

        <!-- Models RecyclerView -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/modelsRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:padding="8dp"
            android:clipToPadding="false"
            android:contentDescription="模型列表，双击可加载模型"
            tools:listitem="@layout/item_model" />

        <!-- Empty State -->
        <LinearLayout
            android:id="@+id/emptyState"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone"
            tools:visibility="visible"
            android:contentDescription="空状态，暂无模型">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/outline_folder_open_24"
                android:alpha="0.5"
                android:contentDescription="空文件夹图标"
                app:tint="?attr/colorOnSurfaceVariant"
                android:importantForAccessibility="no" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="暂无模型"
                android:textSize="16sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:contentDescription="暂无模型"
                android:importantForAccessibility="yes" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="点击上方按钮导入模型"
                android:textSize="14sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:contentDescription="请点击上方导入模型按钮来添加模型"
                android:importantForAccessibility="yes" />

        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
